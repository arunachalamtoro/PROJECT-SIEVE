{
  "name": "project-sieve",
  "version": "1.0.1",
  "description": "AI-powered PR analyzer with semantic dependency graph — knows the blast radius of every code change",
  "type": "module",
  "main": "dist/cli/index.js",
  "bin": {
    "sieve": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "sieve": "tsx src/cli/index.ts",
    "lint": "tsc --noEmit",
    "download-grammars": "tsx scripts/download-grammars.ts",
    "prepare": "tsx scripts/download-grammars.ts"
  },
  "keywords": [
    "code-review",
    "pr-analyzer",
    "dependency-graph",
    "ast",
    "tree-sitter",
    "mcp",
    "claude",
    "ai"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=22.5.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@lancedb/lancedb": "^0.15.0",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@xenova/transformers": "^2.17.2",
    "apache-arrow": "^18.1.0",
    "chokidar": "^4.0.3",
    "commander": "^13.1.0",
    "ignore": "^7.0.4",
    "octokit": "^4.1.2",
    "parse-diff": "^0.11.1",
    "sharp": "^0.35.1",
    "tree-sitter-wasms": "^0.1.13",
    "web-tree-sitter": "^0.24.7",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.3"
  }
}
